rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function memberPath(appId, uid) {
      return /databases/$(database)/documents/artifacts/$(appId)/private/data/accessMembers/$(uid);
    }

    function globalMemberPath(uid) {
      return /databases/$(database)/documents/sys_globalAccessMembers/$(uid);
    }

    function memberDirectoryPath(appId, emailKey) {
      return /databases/$(database)/documents/artifacts/$(appId)/private/data/memberDirectory/$(emailKey);
    }

    function hasVerifiedEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email_verified == true;
    }

    function selfEmailKey() {
      return request.auth.token.email.lower().trim();
    }

    function selfDirectory(appId) {
      return get(memberDirectoryPath(appId, selfEmailKey()));
    }

    function selfDirectoryExists(appId) {
      return hasVerifiedEmail()
        && exists(memberDirectoryPath(appId, selfEmailKey()));
    }

    function selfMember(appId) {
      return get(memberPath(appId, request.auth.uid));
    }

    function selfGlobalMember() {
      return get(globalMemberPath(request.auth.uid));
    }

    function isActiveGlobalMember() {
      return signedIn()
        && exists(globalMemberPath(request.auth.uid))
        && selfGlobalMember().data.isActive == true;
    }

    function isGlobalAdmin() {
      return isActiveGlobalMember()
        && selfGlobalMember().data.role == 'admin';
    }

    function isActiveMember(appId) {
      return signedIn()
        && exists(memberPath(appId, request.auth.uid))
        && selfMember(appId).data.isActive == true;
    }

    function hasRole(appId, role) {
      return isActiveMember(appId) && selfMember(appId).data.role == role;
    }

    function isAdmin(appId) {
      return hasRole(appId, 'admin') || isGlobalAdmin();
    }

    function isReception(appId) {
      return hasRole(appId, 'reception');
    }

    function isStaff(appId) {
      return hasRole(appId, 'staff');
    }

    function canReadOps(appId) {
      return isAdmin(appId) || isReception(appId) || isStaff(appId);
    }

    function assignedToRoom(appId, roomId) {
      return isStaff(appId) && selfMember(appId).data.assignedRoomIds.hasAny([roomId]);
    }

    function canManageRoom(appId, roomId) {
      return isAdmin(appId) || assignedToRoom(appId, roomId);
    }

    function canOperateAssignedRoom(appId, roomId) {
      return isAdmin(appId) || assignedToRoom(appId, roomId);
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).changedKeys();
    }

    function canProvisionSelfFromRoster(appId, uid) {
      return hasVerifiedEmail()
        && request.auth.uid == uid
        && selfDirectoryExists(appId)
        && selfDirectory(appId).data.email.lower().trim() == selfEmailKey()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email.lower().trim() == selfEmailKey()
        && request.resource.data.displayName == selfDirectory(appId).data.displayName
        && request.resource.data.grade == selfDirectory(appId).data.grade
        && request.resource.data.role == 'staff'
        && request.resource.data.isActive == true
        && request.resource.data.assignedRoomIds.size() == 0
        && request.resource.data.authorizationSource == 'roster';
    }

    match /sys_globalAccessMembers/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isGlobalAdmin());
      allow list: if isGlobalAdmin();
      allow create, update, delete: if isGlobalAdmin();
    }

    match /artifacts/{appId}/public/data/config/{documentId} {
      allow read: if canReadOps(appId);
      allow create, update, delete: if isAdmin(appId);
    }

    match /artifacts/{appId}/public/data/lanes/{laneId} {
      allow read: if canReadOps(appId)
        && (isAdmin(appId) || isReception(appId) || assignedToRoom(appId, resource.data.roomId));

      allow create, delete: if isAdmin(appId);

      allow update: if isAdmin(appId)
        || (
          isReception(appId)
          && changedKeys().hasOnly(['receptionStatus', 'selectedOptions', 'receptionNotes', 'updatedAt'])
        )
        || (
          canOperateAssignedRoom(appId, resource.data.roomId)
          && changedKeys().hasOnly(['status', 'pauseReasonId', 'staffName', 'updatedAt', 'selectedOptions', 'receptionNotes'])
          && request.resource.data.receptionStatus == resource.data.receptionStatus
        )
        || (
          canOperateAssignedRoom(appId, resource.data.roomId)
          && changedKeys().hasOnly(['status', 'staffName', 'updatedAt', 'receptionStatus'])
          && resource.data.receptionStatus == 'guiding'
          && request.resource.data.receptionStatus == 'available'
          && request.resource.data.status == 'occupied'
        );
    }

    match /artifacts/{appId}/public/data/roomState/{roomId} {
      allow read: if canReadOps(appId)
        && (isAdmin(appId) || isReception(appId) || assignedToRoom(appId, roomId));
      allow create, update, delete: if canManageRoom(appId, roomId);
    }

    match /artifacts/{appId}/private/data/accessMembers/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin(appId));
      allow list: if isAdmin(appId);
      allow create: if isAdmin(appId) || canProvisionSelfFromRoster(appId, uid);
      allow update, delete: if isAdmin(appId);
    }

    match /artifacts/{appId}/private/data/memberDirectory/{emailKey} {
      allow get: if isAdmin(appId)
        || (
          hasVerifiedEmail()
          && emailKey == selfEmailKey()
        );
      allow list: if isAdmin(appId);
      allow create, update, delete: if isAdmin(appId);
    }

    match /artifacts/{appId}/private/data/accessRequests/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin(appId));
      allow list: if isAdmin(appId);

      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isAdmin(appId)
        || (
          signedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.status == resource.data.status
          && changedKeys().hasOnly(['email', 'displayName', 'lastSeenAt', 'updatedAt'])
        );

      allow delete: if isAdmin(appId);
    }

    match /sys_registry/{appId} {
      allow read: if signedIn();
      allow write: if isAdmin(appId);
    }
  }
}
